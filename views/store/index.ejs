<%- include('../partials/head') %>
</head>
<body class="bg-gray-50">
  <%- include('../partials/nav') %>

  <main class="container mx-auto px-4 py-10 max-w-6xl">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold text-gray-800">Welcome to airbnb index page: </h2>
      
    </div>

    <% if (!registeredHomes || registeredHomes.length === 0) { %>
      <div class="text-center py-16 bg-white rounded-2xl shadow-sm border border-gray-200">
        <p class="text-gray-500 text-lg">No homes have been registered yet.</p>
      </div>
    <% } else { %>
      <ul style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:24px; list-style:none; padding:0; margin:0;">
        <% registeredHomes.forEach(home => { %>
          <li style="background:#fff; border:1px solid #e5e7eb; border-radius:16px; overflow:hidden; box-shadow:0 1px 2px rgba(0,0,0,0.05);">
            <a href="/homes/<%= home._id %>" style="display:block; text-decoration:none; color:inherit;">
              <% if (home.photoUrl) { %>
                <img
                  src="https://images.pexels.com/photos/30767883/pexels-photo-30767883.jpeg"
                  alt="<%= home.houseName %>"
                  loading="lazy"
                  style="width:100%; height:180px; object-fit:cover; display:block;"
                />
              <% } else { %>
                <div style="width:100%; height:180px; background:linear-gradient(to bottom right,#dbeafe,#ede9fe); display:flex; align-items:center; justify-content:center; color:#6b7280; font-size:14px;">
                  No image available
                </div>
              <% } %>

              <div style="padding:20px;">
                <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:8px;">
                  <div style="min-width:0;">
                    <h3 style="font-size:18px; font-weight:600; color:#111827; margin:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                      <i class="fa-solid fa-house" style="color:#6b7280; margin-right:6px; font-size:15px;"></i><%= home.houseName %>
                    </h3>

                    <h3 style="font-size:18px; font-weight:600; color:#737b8b; margin:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                      <i class="fa-solid fa-location-dot" style="color:#6b7280; margin-right:9px; 
                      margin-top:10px;
                      padding:2px;
                      font-size:15px;"></i><%= home.location %>
                    </h3>
                    
                  </div>
                  <% if (home.rating) { %>
                    <span style="flex-shrink:0; background:#fef9c3; color:#854d0e; padding:4px 12px; border-radius:9999px; font-size:14px; font-weight:500;">
                      <i class="fa-solid fa-star"></i> <%= home.rating %>
                    </span>
                  <% } %>
                </div>

                <p style="margin-top:9px; color:#374151;">
                  <i class="fa-solid fa-tag" style="color:#6b7280; margin-right:2px;
                  padding:2px;
                  "></i>
                  <span style="font-weight:600; color:#111827;">Rs<%= home.price %></span>
                  <span style="font-size:14px; color:#6b7280;"> / night</span>
                </p>
                <button class="bg-green-300 p-2">Book</button>
              </div>
              
            </a>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </main>
</body>
</html>